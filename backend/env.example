# F-Proxy Environment Variables
# Copy this file to .env and fill in deployment-specific values.
# Never commit real credentials or production webhook URLs.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@example.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=fproxy

# Admin authentication (change this to a strong random string!)
ADMIN_SECRET_KEY=change-this-to-random-secret

# Go Proxy configuration
PROXY_PORT=8003

# Node.js Backend configuration
BACKEND_PORT=3005

# Frontend URL (for referral links)
FRONTEND_URL=https://example.com

# Optional: Debug mode
DEBUG=false

# SePay Payment Gateway
SEPAY_ACCOUNT=your-account-id
SEPAY_BANK=your-bank-code
SEPAY_API_KEY=your-sepay-api-key

# Discord Bot Webhook (for role assignment)
DISCORD_BOT_WEBHOOK_URL=https://example.com/webhook/payment
DISCORD_BOT_WEBHOOK_SECRET=your-discord-webhook-secret

# OpenHands Webhook Authentication (for third-party key management)
OPENHANDS_WEBHOOK_SECRET=your-webhook-secret-here
